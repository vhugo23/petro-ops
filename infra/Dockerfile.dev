FROM node:22-bookworm

# Create non-root user
RUN useradd -ms /bin/bash devuser

# Install basic tools
RUN apt-get update && apt-get install -y \
    git \
    curl \
    vim \
    nano \
    python3 \
    python3-pip \
    && rm -rf /var/lib/apt/lists/*

# Set working directory
WORKDIR /workspace

# Use non-root user
USER devuser

CMD ["/bin/bash"]